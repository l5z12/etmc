{
  "schemaVersion": 1,
  "id": "etmc",
  "version": "${version}",
  "name": "etmc",
  "description": "EasyTier P2P multiplayer, in-game. Host your world or join a friend over a peer-to-peer mesh — no port-forwarding, no TUN driver, no admin.",
  "authors": [
    "L5Z12"
  ],
  "contact": {
    "homepage": "https://github.com/L5Z12/etmc",
    "sources": "https://github.com/L5Z12/etmc"
  },
  "license": "GPL-3.0-or-later",
  "environment": "client",
  "entrypoints": {
    "client": [
      "dev.l5z12.etmc.client.EtmcClient"
    ]
  },
  "mixins": [
    "etmc.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "${minecraft_dependency}",
    "java": ">=21",
    "${fabric_api_id}": "*"
  },
  "suggests": {}
}
