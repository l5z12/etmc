---
import BaseLayout from '../layouts/BaseLayout.astro';

const features = [
  { ico: '🧩', title: 'No port-forwarding', body: 'EasyTier coordinates a P2P mesh through your relay and punches through NAT. Friends just need the code.' },
  { ico: '🚫', title: 'No TUN, no admin', body: 'Runs fully in userspace via the EasyTier data plane — no virtual adapter, no driver, no elevation.' },
  { ico: '🧱', title: 'Multi-platform', body: 'Native libraries for Windows and Linux (x64 + arm64) bundled; macOS produced in CI.' },
  { ico: '🔌', title: 'Mod-compatible', body: 'A transparent transport below the protocol — composes with mods like ViaFabricPlus.' },
];

const diagram = `Host                                          Joiner
─────                                         ──────
"Open to LAN"  127.0.0.1:LAN                  Minecraft client
       ^                                             | connects to
       | loopback                                    v 127.0.0.1:PROXY
  HostShare ──── data-plane TCP ───┐       ┌─── JoinProxy
       |                           |       |
  EasyTier (no_tun, 10.126.126.1)  |       |  EasyTier (no_tun, dhcp)
       └────────── EasyTier mesh via your relay ──────────┘`;
---

<BaseLayout title="etmc">
  <section class="hero">
    <div class="container">
      <span class="tag">FABRIC · NEOFORGE · FORGE · MC 1.17 – 26</span>
      <h1>etmc</h1>
      <p class="lead">
        EasyTier P2P multiplayer, in-game. Host your world or join a friend over a
        peer-to-peer mesh — no port-forwarding, no TUN driver, no admin.
      </p>
      <div class="btn-row" style="justify-content:center">
        <a class="btn btn-primary" href="/docs">Get started</a>
        <a class="btn" href="/generator">Config generator</a>
        <a class="btn" href="https://github.com/L5Z12/etmc" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </section>
  <div class="grassbar"></div>
  <div class="dirtbar"></div>

  <div class="container">
    <section class="grid" style="margin-top:30px">
      {features.map((f) => (
        <div class="panel feature">
          <div class="ico">{f.ico}</div>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </div>
      ))}
    </section>

    <h2>How it works</h2>
    <div class="panel slot">
      <pre><code>{diagram}</code></pre>
      <p class="muted">
        Minecraft only ever talks to <code>127.0.0.1</code>. etmc bridges that loopback
        socket to the mesh in userspace, so the vanilla networking — and other mods — work unchanged.
      </p>
    </div>

    <h2>Quick start</h2>
    <div class="panel">
      <ol>
        <li>Install the Fabric mod (needs Fabric API).</li>
        <li>Open the menu with <span class="kbd">G</span> or <code>/etmc menu</code>.</li>
        <li>In <strong>Settings</strong>, add your EasyTier relay, e.g. <code>tcp://my.relay:11010</code>.</li>
        <li><strong>Host this world</strong> → share the join code. Friends pick <strong>Join with a code</strong>.</li>
      </ol>
      <div class="btn-row">
        <a class="btn" href="/docs">Read the docs</a>
        <a class="btn" href="/docs/connect-url">Connect via config URL</a>
      </div>
    </div>

    <div class="panel center" style="margin:34px 0 50px">
      <h2 style="margin-top:0">Generate a server config</h2>
      <p>Build a shareable EasyTier config file your players join with a single link.</p>
      <a class="btn btn-primary" href="/generator">Open the generator →</a>
    </div>
  </div>
</BaseLayout>
